# Етап 1: Builder
FROM python:3.9-slim as builder

WORKDIR /app
# Створюємо віртуальне середовище
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Встановлюємо CPU-версії (значно зменшує розмір!) та відключаємо кеш pip
RUN pip install --no-cache-dir torch torchvision pillow --index-url https://download.pytorch.org/whl/cpu

# Етап 2: Runtime
FROM python:3.9-slim

WORKDIR /app
# Копіюємо лише готові бібліотеки з першого етапу
COPY --from=builder /opt/venv /opt/venv

ENV PATH="/opt/venv/bin:$PATH"
# Не встановлюємо apt-пакети, мінімізуємо шари
COPY model.pt inference.py ./

ENTRYPOINT ["python", "inference.py"]